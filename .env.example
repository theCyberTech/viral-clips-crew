# =============================================================================
# Viral Clips Crew — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values. Never commit real keys.
#
# Required:
#   OPENAI_API_KEY — Used by extracts.py to find viral segments via GPT-4o
#   GEMINI_API_KEY  — Used by crew.py to match extract text to SRT timestamps
# =============================================================================

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
